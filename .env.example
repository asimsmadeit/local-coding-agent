# ──────────────────────────────────────────────────────────────────────
# Copy to .env and fill in. Everything here is environment-specific;
# nothing in the repo hardcodes endpoints or credentials.
# ──────────────────────────────────────────────────────────────────────

# ── Planner model (frontier, via Bedrock — company environment only) ──
# Goose's bedrock provider uses the standard AWS credential chain.
AWS_REGION=us-east-1
AWS_PROFILE=
# Bedrock model for planning. At company: ensure PrivateLink endpoint +
# scoped endpoint policy (see IMPLEMENTATION_STEPS.md Phase 2).
GOOSE_PLANNER_MODEL=us.anthropic.claude-sonnet-4-5-20250929-v1:0

# ── Implementer model (OpenAI-compatible endpoint) ────────────────────
# Default = the local dev tier that ships with this repo: Qwen3-4B behind
# the LiteLLM gateway (the "dev-coder" alias on :4000). Works out of the box.
# At company: point at the vLLM box (e.g. qwen3-coder-30b) behind its proxy.
# See docs/BEDROCK_INTEGRATION.md for Bedrock and remote endpoints.
LOCAL_LLM_BASE_URL=http://localhost:4000/v1
LOCAL_LLM_MODEL=dev-coder
LOCAL_LLM_API_KEY=local

# ── OpenHands coder (the delegated implementer agent) ─────────────────
# LiteLLM format:
#   openai-compatible:  openai/<model-name>  + base_url above
#   bedrock:            bedrock/us.anthropic.claude-sonnet-4-5-20250929-v1:0
#                       (leave base_url/api_key EMPTY for bedrock)
# NOTE: the endpoint must return STRUCTURED tool_calls and serve >=32k
# context — verification curl in docs/BEDROCK_INTEGRATION.md.
OPENHANDS_LLM_MODEL=openai/dev-coder
OPENHANDS_LLM_BASE_URL=${LOCAL_LLM_BASE_URL}
OPENHANDS_LLM_API_KEY=${LOCAL_LLM_API_KEY}
# Hard ceiling per delegated task (escalation guard / cost control)
OPENHANDS_MAX_ITERATIONS=50

# ── Shared memory stack (OpenMemory MCP: qdrant + api + ui) ───────────
OPENMEMORY_MCP_URL=http://localhost:8765
# mem0 inside OpenMemory needs an extraction LLM + embedder. Fully local:
# llama.cpp servers behind the LiteLLM gateway (scripts/local-llm-up.sh);
# the OpenMemory container reaches it at host.docker.internal:4000.
# Model/provider pinning happens via the OpenMemory config API in
# scripts/memory-up.sh (this image ignores env for that).
# A user id shared by BOTH agents so they read/write one memory space.
MEMORY_USER_ID=tesims
# Curated memory notes (verbatim markdown + INDEX.md, the Claude Code model).
# Shared by both agents. Keep OUTSIDE work repos; back it up — it's the
# agents' accumulated knowledge.
MEMORY_NOTES_DIR=${HOME}/.local/share/agent-memory
