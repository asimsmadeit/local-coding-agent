# ──────────────────────────────────────────────────────────────────────
# Copy to .env and fill in. Everything here is environment-specific;
# nothing in the repo hardcodes endpoints or credentials.
# ALL models run on AWS Bedrock — no local inference, no GPU required.
# Works on macOS, Linux, and Windows (use the `localagent` CLI on Windows;
# the scripts/*.sh wrappers are macOS/Linux conveniences).
# ──────────────────────────────────────────────────────────────────────

# ── AWS (every model + the embeddings go through Bedrock) ─────────────
# Standard boto3 credential chain: static keys, ~/.aws config/SSO, or env.
# Everything runs in-process now (no container), so the embedder uses the
# same chain as Goose. Prefer the DEFAULT profile; if you set AWS_PROFILE,
# leave it UNSET rather than empty (boto3 hard-fails on an empty profile).
# At company: PrivateLink endpoint + scoped endpoint policy
# (see IMPLEMENTATION_STEPS.md Phase 2).
AWS_REGION=us-east-1
AWS_PROFILE=

# ── Planner model (Goose orchestrator, Bedrock model id) ──────────────
GOOSE_PLANNER_MODEL=us.anthropic.claude-sonnet-4-5-20250929-v1:0

# ── Implementer model (OpenHands coder, LiteLLM model-string format) ──
# bedrock/<model-id>; BASE_URL and API_KEY stay EMPTY — the boto3
# credential chain is used. Claude = strongest; cheaper alternative:
#   OPENHANDS_LLM_MODEL=bedrock/us.amazon.nova-pro-v1:0
# Requirement either way: structured tool_calls + >=32k context
# (verification curl in docs/BEDROCK_INTEGRATION.md).
OPENHANDS_LLM_MODEL=bedrock/us.anthropic.claude-sonnet-4-5-20250929-v1:0
OPENHANDS_LLM_BASE_URL=
OPENHANDS_LLM_API_KEY=
# Hard ceiling per delegated task (escalation guard / cost control)
OPENHANDS_MAX_ITERATIONS=50

# ── Shared memory (both layers run IN-PROCESS — no containers) ────────
# Episodic semantic recall: Bedrock Titan embeddings + a local SQLite
# vector store, searched in-process with NumPy. No OpenMemory image, no
# Qdrant, no mcp-proxy, nothing to download. Embeddings → Titan v2.
MEMORY_EMBEDDER_MODEL=amazon.titan-embed-text-v2:0
MEMORY_EMBEDDING_DIMS=1024
# A user id shared by BOTH agents so they read/write one memory space.
MEMORY_USER_ID=tesims
# Curated memory notes (verbatim markdown files + INDEX.md).
# Shared by both agents. Keep OUTSIDE work repos; back it up — it's the
# agents' accumulated knowledge. Leave empty for the per-OS default
# (~/.local/share/agent-memory).
MEMORY_NOTES_DIR=
# Episodic vector DB (SQLite). Kept separate from the notes dir so the
# notes' git history doesn't churn on a binary. Empty = per-OS default
# (~/.local/share/agent-episodic).
MEMORY_EPISODIC_DIR=
